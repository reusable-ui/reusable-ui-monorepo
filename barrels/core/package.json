{
  "name": "@reusable-ui/core",
  "version": "6.15.2",
  "description": "A set of reusable-ui packages which are responsible for building any component.",
  "keywords": [
    "core",
    "framework",
    "component",
    "styled",
    "react",
    "reusable-ui"
  ],
  "author": "HeyMarco <31385284+heyymarco@users.noreply.github.com>",
  "homepage": "https://reusableui.org",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reusable-ui/reusable-ui-monorepo.git"
  },
  "main": "dist/core.js",
  "types": "dist/core.d.ts",
  "type": "module",
  "exports": {
    ".": "./dist/core.js",
    "./index": "./dist/core.js",
    "./index.js": "./dist/core.js"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist playwright/.cache playwright-report test-results .next",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "lint": "eslint .",
    "build": "npm run clean && npm run tsc && npm run lint",
    "ncu": "ncu --peer",
    "ncu:upgrade": "ncu --peer --upgrade",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules npx jest"
  },
  "dependencies": {
    "@reusable-ui/auto-focusable": "^6.6.2",
    "@reusable-ui/floatable": "^6.5.1",
    "@reusable-ui/focuses": "^6.5.0",
    "@reusable-ui/global-stackable": "^6.6.0",
    "@reusable-ui/navigations": "^6.5.0",
    "@reusable-ui/nodes": "^6.5.0",
    "@reusable-ui/numbers": "^6.5.0",
    "@reusable-ui/pointer-capturable": "^6.6.0",
    "@reusable-ui/semantics": "^6.5.0",
    "@reusable-ui/types": "^6.12.0"
  },
  "peerDependencies": {
    "@reusable-ui/border-config": "^6.5.0",
    "@reusable-ui/breakpoint-config": "^6.5.0",
    "@reusable-ui/color-config": "^6.5.0",
    "@reusable-ui/groupable": "^6.5.0",
    "@reusable-ui/spacer-config": "^6.5.0",
    "@reusable-ui/typo-config": "^6.5.1"
  }
}
